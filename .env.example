# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/darsnote?schema=public"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# URL aplikasi (tanpa trailing slash)
NEXTAUTH_URL="https://dars.saif.co.id"

# Secret acak minimal 32 karakter — generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Buat di https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Email / SMTP ────────────────────────────────────────────────────────────
# Untuk magic link & verifikasi email
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
# Alamat pengirim yang tampil di inbox user
EMAIL_FROM="noreply@dars.saif.co.id"

# ─── Groq API (Whisper transkripsi) ──────────────────────────────────────────
# Dapatkan di https://console.groq.com/keys
GROQ_API_KEY=""

# ─── Anthropic API (Claude ringkasan + dalil) ────────────────────────────────
# Dapatkan di https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# ─── Redis (BullMQ queue) ────────────────────────────────────────────────────
# Format: redis://[:password@]host:port[/db]
REDIS_URL="redis://localhost:6379"
