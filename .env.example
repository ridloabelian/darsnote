# Local Node/Next fallback only. Cloudflare runtime uses D1 binding DB.
DATABASE_URL="file:./prisma/local.db"

# NextAuth
NEXTAUTH_URL="http://localhost:8787"
NEXTAUTH_SECRET=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Password reset email via Resend HTTP API
RESEND_API_KEY=""
EMAIL_FROM="DarsNote <noreply@dars.saif.co.id>"
# Local development helper: returns resetUrl from forgot-password API
RESET_PASSWORD_DEBUG_LINK="true"

# ─── Groq API (Whisper & LLM Analisis) ───────────────────────────────────────
# Dapatkan di https://console.groq.com/keys
# Digunakan untuk:
# 1. Transkripsi (Whisper-large-v3-turbo)
# 2. Ringkasan & Deteksi Dalil (Llama-3.1-8b-instant)
GROQ_API_KEY=""
GROQ_TEXT_MODEL="llama-3.1-8b-instant"

# R2 bucket name. Production uses the MEDIA_BUCKET binding for multipart upload.
R2_BUCKET_NAME="darsnote-media"
