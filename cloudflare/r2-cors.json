{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://dars.saif.co.id",
          "http://localhost:3000",
          "http://localhost:8787"
        ],
        "methods": [
          "PUT",
          "GET",
          "HEAD"
        ],
        "headers": [
          "content-type"
        ]
      },
      "exposeHeaders": [
        "etag"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
