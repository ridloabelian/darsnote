{
  "name": "darsnote-init",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "cf:build": "opennextjs-cloudflare build",
    "preview": "npm run cf:build && wrangler dev --port 8787",
    "deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "deploy:dry-run": "npm run cf:build && wrangler deploy --dry-run",
    "upload": "npm run cf:build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "d1:migrate:local": "wrangler d1 migrations apply darsnote --local",
    "d1:migrate:remote": "wrangler d1 migrations apply darsnote --remote",
    "prisma:generate": "prisma generate",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "worker": "echo \"Background jobs run on Cloudflare Workflows\""
  },
  "dependencies": {
    "@cloudflare/containers": "^0.3.4",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@opennextjs/cloudflare": "^1.19.11",
    "@prisma/adapter-d1": "^6.19.0",
    "@prisma/client": "^6.19.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "^15.5.18",
    "next-auth": "^4.24.14",
    "prisma": "^6.19.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260520.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^17.4.2",
    "eslint": "^8",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.93.0"
  }
}
